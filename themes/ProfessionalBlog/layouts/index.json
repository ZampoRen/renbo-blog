{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "url" .Permalink "content" .Plain "summary" .Summary "date" (.Date.Format "2006-01-02") "tags" .Params.tags "categories" .Params.categories "description" .Params.description) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}